@page "/Account/RequestTenant"

@using Microsoft.AspNetCore.WebUtilities

<PageTitle>Request a company tenant</PageTitle>

<h1>Request a company tenant</h1>
<p class="text-secondary">
    Create the intended company administrator account. A WorkSync super user
    will approve the company, assign its six-digit tenant ID, and activate this
    account with the Admin role.
</p>

@if (!string.IsNullOrWhiteSpace(Message))
{
    <div class="alert alert-info" role="status">@Message</div>
}

<form action="/Account/RequestTenant" method="post" class="col-lg-6">
    <AntiforgeryToken />
    <div class="form-floating mb-3">
        <input class="form-control" id="companyName" name="companyName"
               maxlength="120" required placeholder="Company name" />
        <label for="companyName">Company name</label>
    </div>
    <div class="form-floating mb-3">
        <input class="form-control" id="firstName" name="firstName"
               maxlength="50" required placeholder="First name" />
        <label for="firstName">Administrator first name</label>
    </div>
    <div class="form-floating mb-3">
        <input class="form-control" id="lastName" name="lastName"
               maxlength="50" required placeholder="Last name" />
        <label for="lastName">Administrator last name</label>
    </div>
    <div class="form-floating mb-3">
        <input class="form-control" id="adminEmail" name="adminEmail"
               type="email" maxlength="256" required placeholder="admin@example.com" />
        <label for="adminEmail">Administrator email</label>
    </div>
    <div class="input-group mb-3">
        <div class="form-floating">
            <input class="form-control" id="tenant-password" name="password"
                   type="password" minlength="6" maxlength="100" required
                   autocomplete="new-password" placeholder="Password" />
            <label for="tenant-password">Password</label>
        </div>
        <button class="btn btn-outline-secondary"
                type="button"
                aria-label="Show or hide password"
                onclick="toggleTenantRequestPassword('tenant-password', this)">
            <i class="bi bi-eye" aria-hidden="true"></i>
        </button>
    </div>
    <div class="input-group mb-3">
        <div class="form-floating">
            <input class="form-control" id="tenant-confirm-password" name="confirmPassword"
                   type="password" minlength="6" maxlength="100" required
                   autocomplete="new-password" placeholder="Confirm password" />
            <label for="tenant-confirm-password">Confirm password</label>
        </div>
        <button class="btn btn-outline-secondary"
                type="button"
                aria-label="Show or hide confirmation password"
                onclick="toggleTenantRequestPassword('tenant-confirm-password', this)">
            <i class="bi bi-eye" aria-hidden="true"></i>
        </button>
    </div>
    <button class="btn btn-primary" type="submit">Submit tenant request</button>
</form>

@code {
    [SupplyParameterFromQuery(Name = "message")]
    private string? Message { get; set; }
}

<script>
    function toggleTenantRequestPassword(fieldId, button) {
        const field = document.getElementById(fieldId);
        const icon = button?.querySelector('i');

        if (!field) return;

        const showPassword = field.type === 'password';
        field.type = showPassword ? 'text' : 'password';

        if (icon) {
            icon.classList.toggle('bi-eye', !showPassword);
            icon.classList.toggle('bi-eye-slash', showPassword);
        }

        button?.setAttribute(
            'aria-label',
            showPassword ? 'Hide password' : 'Show password');
    }
</script>
