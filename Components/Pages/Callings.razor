@page "/callings"
@rendermode InteractiveServer
@inject WorkSyncService Service
@inject NavigationManager Navigation

@attribute [Authorize(Roles = "Admin,Leader")]

<PageTitle>Callings | WorkSync</PageTitle>

<h1>Calling Tracker</h1>

@if (showForm)
{
    <div class="card" style="margin-bottom: 2rem;">
        <h3>@(isEditing ? "Edit Calling" : "Create New Calling")</h3>
        
        <!-- EditForm with validation - OnValidSubmit only fires when all validation passes -->
        <EditForm EditContext="editContext" OnValidSubmit="SaveCalling" OnInvalidSubmit="HandleInvalidSubmit">
            <DataAnnotationsValidator />
            
            <!-- Validation summary - displays all validation errors at the top -->
            <div class="validation-summary-errors" role="alert" style="display: @(formError ? "block" : "none")">
                <ul>
                    @if (formError)
                    {
                        @foreach (var error in validationErrors)
                        {
                            <li>@error</li>
                        }
                    }
                </ul>
            </div>
            
            <div class="form-grid">
                <!-- Each form field shows individual validation message below it -->
                <div class="form-field">
                    <label>Calling Title</label>
                    <InputText @bind-Value="currentCalling.Title" />
                    <ValidationMessage For="@(() => currentCalling.Title)" />
                </div>

                <div class="form-field">
                    <label>Organization</label>
                    <InputText @bind-Value="currentCalling.Organization" />
                    <ValidationMessage For="@(() => currentCalling.Organization)" />
                </div>

                <div class="form-field">
                    <label>Assigned Member</label>
                    <InputText @bind-Value="currentCalling.MemberAssigned" />
                    <ValidationMessage For="@(() => currentCalling.MemberAssigned)" />
                </div>

                <div class="form-field">
                    <label>Status</label>
                    <InputSelect @bind-Value="currentCalling.Status">
                        <option value="Open">Open</option>
                        <option value="Filled">Filled</option>
                        <option value="Released">Released</option>
                    </InputSelect>
                    <ValidationMessage For="@(() => currentCalling.Status)" />
                </div>

                <div class="form-field">
                    <label>
                        <InputCheckbox @bind-Value="currentCalling.NeedsFollowUp" />
                        Needs Follow-Up
                    </label>
                </div>

                <div class="form-field">
                    <label>Date Extended</label>
                    <InputDate @bind-Value="currentCalling.DateExtended" />
                    <ValidationMessage For="@(() => currentCalling.DateExtended)" />
                </div>

                <div class="form-field">
                    <label>Date Sustained</label>
                    <InputDate @bind-Value="currentCalling.DateSustained" />
                    <ValidationMessage For="@(() => currentCalling.DateSustained)" />
                </div>

                <div class="form-field">
                    <label>Date Released</label>
                    <InputDate @bind-Value="currentCalling.DateReleased" />
                    <ValidationMessage For="@(() => currentCalling.DateReleased)" />
                </div>

                <div class="form-field">
                    <label>Notes</label>
                    <InputTextArea @bind-Value="currentCalling.Notes" rows="3" />
                    <ValidationMessage For="@(() => currentCalling.Notes)" />
                </div>
            </div>

            <div class="button-group">
                <button type="submit" class="btn-primary">@(isEditing ? "Update Calling" : "+ Add Calling")</button>
                <button type="button" class="btn-secondary" @onclick="CancelForm">Cancel</button>
            </div>
        </EditForm>
    </div>
}

<div style="margin-bottom: 1rem;">
    <button class="btn-primary" @onclick="ShowCreateForm">+ Add New Calling</button>
    <button class="btn-secondary" @onclick="RefreshData" style="margin-left: 0.5rem;">Refresh</button>
</div>

<!-- Filter row for searching and filtering callings -->
<div class="filter-row">
    <div class="search-box">
        <label class="visually-hidden" for="calling-search">Search callings</label>
        <span class="search-icon">🔍</span>
        <InputText id="calling-search"
                   @bind-Value="searchText"
                   placeholder="Search callings..." />
    </div>

    <label class="visually-hidden" for="calling-status-filter">Filter callings by status</label>
    <InputSelect id="calling-status-filter" @bind-Value="statusFilter">
        <option value="">All Status</option>
        <option value="Open">Open</option>
        <option value="Filled">Filled</option>
        <option value="Released">Released</option>
    </InputSelect>
</div>

@if (isLoading)
{
    <div class="loading">
        <p>Loading callings...</p>
    </div>
}
else if (errorMessage != null)
{
    <div class="alert alert-danger">
        <p><strong>Error:</strong> @errorMessage</p>
    </div>
}
else if (FilteredCallings.Any())
{
    <div class="table-responsive">
        <table class="table">
            <thead>
                <tr>
                    <th>Title</th>
                    <th>Organization</th>
                    <th>Member</th>
                    <th>Status</th>
                    <th>Follow-Up</th>
                    <th>Date Extended</th>
                    <th>Date Sustained</th>
                    <th>Date Released</th>
                    <th>Notes</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                <!-- Display filtered callings with edit and delete buttons -->
                @foreach (var calling in FilteredCallings)
                {
                    <tr>
                        <td>@calling.Title</td>
                        <td>@calling.Organization</td>
                        <td>@calling.MemberAssigned</td>
                        <td>@calling.Status</td>
                        <td>@(calling.NeedsFollowUp ? "Yes" : "No")</td>
                        <td>@(calling.DateExtended?.ToString("yyyy-MM-dd") ?? "-")</td>
                        <td>@(calling.DateSustained?.ToString("yyyy-MM-dd") ?? "-")</td>
                        <td>@(calling.DateReleased?.ToString("yyyy-MM-dd") ?? "-")</td>
                        <td>@calling.Notes</td>
                        <td>
                            <button class="btn-edit" @onclick="() => EditCalling(calling)">Edit</button>
                            <button class="btn-delete" @onclick="() => DeleteCalling(calling.Id)">Delete</button>
                         </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    <div class="alert alert-info">
        <small>Total callings: @FilteredCallings.Count() (filtered from @callings.Count total)</small>
    </div>
}
else
{
    <div class="empty-state">
        <p>No callings found. Click "Add New Calling" to get started!</p>
    </div>
}

<!-- Delete confirmation modal -->
@if (showDeleteConfirmation)
{
    <div class="modal-overlay">
        <div class="modal-content">
            <h3>Confirm Delete</h3>
            <p>Are you sure you want to delete this calling?</p>
            <p><strong>@callingToDelete?.Title</strong> - @callingToDelete?.Organization</p>
            <div class="button-group">
                <button class="btn-delete" @onclick="ConfirmDelete">Yes, Delete</button>
                <button class="btn-secondary" @onclick="CancelDelete">Cancel</button>
            </div>
        </div>
    </div>
}

@code {
    // Data and state properties
    private List<Calling> callings = new();
    private Calling currentCalling = new();
    private Calling? callingToDelete = null;
    private EditContext? editContext;
    private bool showForm = false;
    private bool isEditing = false;
    private bool showDeleteConfirmation = false;
    private bool isLoading = true;
    private bool formError = false;
    private List<string> validationErrors = new();
    private string? errorMessage = null;
    
    // Filter properties
    private string searchText = string.Empty;
    private string statusFilter = string.Empty;

    // Load data when page first renders
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await LoadData();
        }
    }

    private async Task RefreshData()
    {
        await LoadData();
    }

    // Fetch all callings from the database
    private async Task LoadData()
    {
        try
        {
            isLoading = true;
            errorMessage = null;
            StateHasChanged();
            
            callings = await Service.GetCallingsAsync();
            
            isLoading = false;
            StateHasChanged();
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
            isLoading = false;
            StateHasChanged();
        }
    }

    // Filter callings based on search text and status filter
    private IEnumerable<Calling> FilteredCallings
    {
        get
        {
            var query = callings.AsEnumerable();

            if (!string.IsNullOrWhiteSpace(searchText))
            {
                query = query.Where(c =>
                    c.Title.Contains(searchText, StringComparison.OrdinalIgnoreCase) ||
                    c.Organization.Contains(searchText, StringComparison.OrdinalIgnoreCase) ||
                    c.MemberAssigned.Contains(searchText, StringComparison.OrdinalIgnoreCase) ||
                    c.Status.Contains(searchText, StringComparison.OrdinalIgnoreCase) ||
                    c.Notes.Contains(searchText, StringComparison.OrdinalIgnoreCase));
            }

            if (!string.IsNullOrWhiteSpace(statusFilter))
            {
                query = query.Where(c => c.Status == statusFilter);
            }

            return query.OrderBy(c => c.Title);
        }
    }

    // Initialize form for creating a new calling
    private void ShowCreateForm()
    {
        currentCalling = new Calling();
        isEditing = false;
        showForm = true;
        formError = false;
        validationErrors.Clear();
        editContext = new EditContext(currentCalling);
        
        // Real-time validation as user types
        editContext.OnFieldChanged += (sender, e) =>
        {
            formError = !editContext.Validate();
            StateHasChanged();
        };
        
        StateHasChanged();
    }

    // Populate form with existing calling data for editing
    private void EditCalling(Calling calling)
    {
        currentCalling = new Calling
        {
            Id = calling.Id,
            Title = calling.Title,
            Organization = calling.Organization,
            MemberAssigned = calling.MemberAssigned,
            Status = calling.Status,
            NeedsFollowUp = calling.NeedsFollowUp,
            DateExtended = calling.DateExtended,
            DateSustained = calling.DateSustained,
            DateReleased = calling.DateReleased,
            Notes = calling.Notes
        };
        isEditing = true;
        showForm = true;
        formError = false;
        validationErrors.Clear();
        editContext = new EditContext(currentCalling);
        
        editContext.OnFieldChanged += (sender, e) =>
        {
            formError = !editContext.Validate();
            StateHasChanged();
        };
        
        StateHasChanged();
    }

    // Collect all validation errors when form submission fails
    private void HandleInvalidSubmit()
    {
        formError = true;
        validationErrors.Clear();
        
        var validationMessages = editContext?.GetValidationMessages();
        if (validationMessages != null)
        {
            validationErrors.AddRange(validationMessages);
        }
        
        StateHasChanged();
    }

    // Save or update calling based on isEditing flag
    private async Task SaveCalling()
    {
        formError = false;
        validationErrors.Clear();
        
        if (isEditing)
        {
            await Service.UpdateCallingAsync(currentCalling);
        }
        else
        {
            await Service.AddCallingAsync(currentCalling);
        }

        showForm = false;
        currentCalling = new Calling();
        await LoadData();
    }

    private void CancelForm()
    {
        showForm = false;
        currentCalling = new Calling();
        isEditing = false;
        formError = false;
        validationErrors.Clear();
        StateHasChanged();
    }

    // Show delete confirmation modal
    private void DeleteCalling(int id)
    {
        callingToDelete = callings.FirstOrDefault(c => c.Id == id);
        showDeleteConfirmation = true;
        StateHasChanged();
    }

    // Perform actual deletion after confirmation
    private async Task ConfirmDelete()
    {
        if (callingToDelete != null)
        {
            await Service.DeleteCallingAsync(callingToDelete.Id);
            showDeleteConfirmation = false;
            callingToDelete = null;
            await LoadData();
        }
    }

    private void CancelDelete()
    {
        showDeleteConfirmation = false;
        callingToDelete = null;
        StateHasChanged();
    }
}
