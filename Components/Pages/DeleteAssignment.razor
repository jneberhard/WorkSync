@page "/assignments/delete/{id:int}"
@rendermode InteractiveServer
@* ==================================================
    DELETE ASSIGNMENT PAGE
    Displays assignment information and allows
    authorized users to confirm deletion.
   ================================================== *@

@attribute [Authorize(Roles = "Admin,Leader")]
@inject WorkSyncService Service
@inject NavigationManager Navigation

<h1>Delete Assignment</h1>

@if (assignment is null)
{
    <p>Assignment not found.</p>
    <a class="btn-secondary" href="/assignments">Back to Assignments</a>
}
else
{
    <div class="confirm-box">
        <p>Are you sure you want to delete this assignment?</p>

        <h2>@assignment.Title</h2>

        <p><strong>Assigned Leader:</strong> @assignment.AssignedLeader</p>
        <p><strong>Organization:</strong> @assignment.Organization</p>
        <p><strong>Due Date:</strong> @assignment.DueDate.ToShortDateString()</p>
        <p><strong>Status:</strong> @assignment.Status</p>

        <div class="button-row">
            <button type="button" class="btn-delete" @onclick="DeleteConfirmed">
                Yes, Delete
            </button>

            <a class="btn-secondary" href="/assignments">Cancel</a>
        </div>
    </div>
}

@code {
    // Assignment ID received from the route parameter
    [Parameter]
    public int Id { get; set; }

    // Stores the assignment selected for deletion
    private AssignmentItem? assignment;

    // Load assignment details when page initializes
    protected override async Task OnInitializedAsync()
    {
        assignment = await Service.GetAssignmentByIdAsync(Id);
    }

    // Delete the assignment and return to the assignments page
    private async Task DeleteConfirmed()
    {
        await Service.DeleteAssignmentAsync(Id);
        Navigation.NavigateTo("/assignments");
    }
}