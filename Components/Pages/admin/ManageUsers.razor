@page "/Admin/ManageUsers"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore
@using WorkSync.Data

@attribute [Authorize(Roles = "Admin")]
@inject UserManager<ApplicationUser> UserManager

<PageTitle>Manage Users - Admin Center</PageTitle>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="text-dark font-weight-bold m-0">User Registration Approvals</h1>

        <a class="btn btn-primary shadow-sm rounded-3 px-3 fw-semibold"
           href="#pending-approval-list">
            <i class="bi bi-bell-fill me-1"></i> Review Requests Now
        </a>
    </div>

    <div id="pending-approval-list"></div>

    @if (!string.IsNullOrEmpty(ApprovalMessage))
    {
        <div class="alert @(ApprovalSucceeded ? "alert-success" : "alert-danger")"
             role="alert">
            <i class="bi @(ApprovalSucceeded ? "bi-check-circle-fill" : "bi-exclamation-circle-fill") me-2"></i>
            @ApprovalMessage
        </div>
    }

    @if (pendingUsers == null)
    {
        <div class="d-flex justify-content-center my-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading registrations...</span>
            </div>
        </div>
    }
    else if (!pendingUsers.Any())
    {
        <div class="card p-5 text-center shadow-sm border-0 rounded-4 bg-light">
            <i class="bi bi-people text-secondary mb-3" style="font-size: 3rem;"></i>
            <h3 class="text-secondary">All clear!</h3>
            <p class="text-muted mb-0">There are no pending user registration requests waiting for approval right now.</p>
        </div>
    }
    else
    {
        <div class="card shadow-sm border-0 rounded-4 overflow-hidden">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th class="px-4 py-3">Name</th>
                            <th class="py-3">Email Address</th>
                            <th class="py-3" style="width: 200px;">Assign Role</th>
                            <th class="text-end px-4 py-3">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var user in pendingUsers)
                        {
                            var approvalFormId = $"approve-user-{user.Id}";

                            <tr>
                                <td class="px-4 font-weight-bold">@user.LastName, @user.FirstName</td>
                                <td class="text-secondary">@user.Email</td>
                                <td>
                                    <select class="form-select form-select-sm rounded-3"
                                            name="role"
                                            form="@approvalFormId"
                                            aria-label="Role for @user.Email">
                                        <option value="Viewer">Viewer</option>
                                        <option value="Leader">Leader</option>
                                        <option value="Admin">Admin</option>
                                    </select>
                                </td>
                                <td class="text-end px-4">
                                    <form id="@approvalFormId"
                                          action="/Admin/ApproveUser"
                                          method="post">
                                        <AntiforgeryToken />
                                        <input type="hidden" name="userId" value="@user.Id" />
                                        <button type="submit"
                                                class="btn btn-sm btn-success rounded-3 px-3 fw-semibold">
                                            <i class="bi bi-person-check-fill me-1"></i> Approve Access
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>


@code {
    private List<ApplicationUser>? pendingUsers;

    [CascadingParameter]
    private HttpContext HttpContext { get; set; } = default!;

    [SupplyParameterFromQuery(Name = "approvalMessage")]
    private string? ApprovalMessage { get; set; }

    [SupplyParameterFromQuery(Name = "approvalSucceeded")]
    private bool ApprovalSucceeded { get; set; }

    protected override async Task OnInitializedAsync()
    {
        await LoadPendingUsers();
    }

    private async Task LoadPendingUsers()
    {
        var currentUser = await UserManager.GetUserAsync(HttpContext.User);
        if (currentUser?.TenantId is not int tenantId)
        {
            pendingUsers = [];
            return;
        }

        pendingUsers = await UserManager.Users
            .Where(u => !u.IsApproved && u.TenantId == tenantId)
            .OrderBy(u => u.LastName)
            .ToListAsync();
    }
}
