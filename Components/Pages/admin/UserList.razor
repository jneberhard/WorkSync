@page "/Admin/UserList"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore
@using WorkSync.Data

@attribute [Authorize(Roles = "Admin")]
@inject UserManager<ApplicationUser> UserManager
@inject RoleManager<IdentityRole> RoleManager
@inject AuthenticationStateProvider AuthenticationStateProvider

<PageTitle>User Directory | WorkSync</PageTitle>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="text-dark font-weight-bold m-0">User Directory</h1>
        <a href="Admin/ManageUsers" class="btn btn-outline-primary roster-approval-link rounded-3 fw-semibold">
            <i class="bi bi-person-plus-fill me-1"></i> View Pending Approvals
        </a>
    </div>

    @* System  Alert *@
    @if (!string.IsNullOrEmpty(statusMessage))
    {
        <div class="alert alert-success alert-dismissible fade show rounded-3 shadow-sm" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> @statusMessage
            <button type="button" class="btn-close" aria-label="Dismiss status message" @onclick="() => statusMessage = null"></button>
        </div>
    }
    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger alert-dismissible fade show rounded-3 shadow-sm" role="alert">
            <i class="bi bi-exclamation-octagon-fill me-2"></i> @errorMessage
            <button type="button" class="btn-close" aria-label="Dismiss error message" @onclick="() => errorMessage = null"></button>
        </div>
    }

    @if (userRoster == null)
    {
        <div class="d-flex justify-content-center my-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading user directory...</span>
            </div>
        </div>
    }
    else if (!userRoster.Any())
    {
        <div class="card p-5 text-center shadow-sm border-0 rounded-4 bg-light">
            <i class="bi bi-people text-secondary mb-3" style="font-size: 3rem;"></i>
            <h3 class="text-secondary">No active users found</h3>
            <p class="text-muted mb-0">There are no approved users registered in the system database yet.</p>
        </div>
    }
    else
    {
        <div class="card shadow-sm border-0 rounded-4 overflow-hidden">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th class="px-4 py-3">First Name</th>
                            <th class="py-3">Last Name</th>
                            <th class="py-3">Email Address</th>
                            <th class="py-3" style="width: 180px;">Role</th>
                            <th class="text-end px-4 py-3" style="width: 220px;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var userModel in userRoster)
                        {
                            @if (userIdToEdit == userModel.Id)
                            {
                                @* EDITABLE MODE ROW LAYOUT *@
                                <tr class="table-warning">
                                    <td class="px-4">
                                        <label class="visually-hidden" for="edit-user-first-name">First name</label>
                                        <input id="edit-user-first-name" type="text" class="form-control form-control-sm rounded-2" @bind="editingUser!.FirstName" />
                                    </td>
                                    <td>
                                        <label class="visually-hidden" for="edit-user-last-name">Last name</label>
                                        <input id="edit-user-last-name" type="text" class="form-control form-control-sm rounded-2" @bind="editingUser!.LastName" />
                                    </td>
                                    <td>
                                        <label class="visually-hidden" for="edit-user-email">Email address</label>
                                        <input id="edit-user-email" type="email" class="form-control form-control-sm rounded-2" @bind="editingUser!.Email" />
                                    </td>
                                    <td>
                                        <label class="visually-hidden" for="edit-user-role">Role</label>
                                        <select id="edit-user-role" class="form-select form-select-sm rounded-2" @bind="editingUser!.SelectedRole">
                                            <option value="Viewer">Viewer</option>
                                            <option value="Leader">Leader</option>
                                            <option value="Admin">Admin</option>
                                        </select>
                                    </td>
                                    <td class="text-end px-4">
                                        <div class="btn-group btn-group-sm" role="group">
                                            <button class="btn btn-success fw-semibold px-3" @onclick="SaveEditedUser">
                                                <i class="bi bi-file-earmark-check-fill me-1"></i> Save
                                            </button>
                                            <button class="btn btn-secondary px-3" @onclick="CancelEdit">
                                                Cancel
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                            else
                            {
                                @* EAD-ONLY STANDARD DISPLAY ROW LAYOUT *@
                                <tr>
                                    <td class="px-4 fw-bold">@userModel.FirstName</td>
                                    <td>@userModel.LastName</td>
                                    <td class="text-secondary">@userModel.Email</td>
                                    <td>
                                        <span class="badge role-badge @(userModel.SelectedRole == "Admin" ? "role-badge-admin" : userModel.SelectedRole == "Leader" ? "role-badge-leader" : "role-badge-viewer") px-2 py-1">
                                            @userModel.SelectedRole
                                        </span>
                                    </td>
                                    <td class="text-end px-4">
                                        @if (userIdToConfirmDelete == userModel.Id)
                                        {
                                            <div class="btn-group btn-group-sm" role="group">
                                                <button class="btn btn-danger fw-semibold px-2" @onclick="() => ConfirmDeleteUser(userModel.Id)">
                                                    Confirm
                                                </button>
                                                <button class="btn btn-secondary text-white px-2" @onclick="CancelDelete">
                                                    Cancel
                                                </button>
                                            </div>
                                        }
                                        else
                                        {
                                            <button class="btn btn-sm btn-outline-secondary rounded-3 px-2 me-1"
                                                    @onclick="() => StartEditingUser(userModel)">
                                                <i class="bi bi-pencil-square me-1"></i> Edit
                                            </button>
                                            <button class="btn btn-sm btn-outline-danger rounded-3 px-2"
                                                    @onclick="() => PromptDeleteUser(userModel.Id)">
                                                <i class="bi bi-trash3-fill me-1"></i> Delete
                                            </button>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

@code {
    private List<UserDisplayModel>? userRoster;
    private string? statusMessage;
    private string? errorMessage;
    private string? userIdToConfirmDelete;

    private string? userIdToEdit;
    private UserDisplayModel? editingUser;
    private int? currentTenantId;

    protected override async Task OnInitializedAsync()
    {
        var principal =
            (await AuthenticationStateProvider.GetAuthenticationStateAsync()).User;
        currentTenantId = (await UserManager.GetUserAsync(principal))?.TenantId;
        await LoadUserRoster();
    }

    private async Task LoadUserRoster()
    {
        var approvedUsers = await UserManager.Users
            .Where(u => u.IsApproved && u.TenantId == currentTenantId)
            .OrderBy(u => u.LastName)
            .ToListAsync();

        var temporaryRoster = new List<UserDisplayModel>();

        foreach (var user in approvedUsers)
        {
            var roles = await UserManager.GetRolesAsync(user);
            var primaryRole = roles.FirstOrDefault() ?? "Viewer";

            temporaryRoster.Add(new UserDisplayModel
            {
                Id = user.Id,
                FirstName = user.FirstName ?? "Unknown",
                LastName = user.LastName ?? "User",
                Email = user.Email ?? string.Empty,
                SelectedRole = primaryRole
            });
        }

        userRoster = temporaryRoster;
    }

       private void StartEditingUser(UserDisplayModel user)
    {
        statusMessage = null;
        errorMessage = null;
        userIdToConfirmDelete = null;

        userIdToEdit = user.Id;
        editingUser = new UserDisplayModel
        {
            Id = user.Id,
            FirstName = user.FirstName,
            LastName = user.LastName,
            Email = user.Email,
            SelectedRole = user.SelectedRole
        };
    }

    private void CancelEdit()
    {
        userIdToEdit = null;
        editingUser = null;
    }

    private async Task SaveEditedUser()
    {
        if (editingUser == null || string.IsNullOrWhiteSpace(editingUser.FirstName) ||
            string.IsNullOrWhiteSpace(editingUser.LastName) || string.IsNullOrWhiteSpace(editingUser.Email))
        {
            errorMessage = "Validation Error: System account input parameters cannot be empty values.";
            return;
        }

        if (editingUser.SelectedRole is not ("Admin" or "Leader" or "Viewer"))
        {
            errorMessage = "Validation Error: The selected tenant role is invalid.";
            return;
        }

        var targetUser = await UserManager.FindByIdAsync(editingUser.Id);
        if (targetUser == null || targetUser.TenantId != currentTenantId)
        {
            errorMessage = "Error: Target user account was not located inside the infrastructure database registries.";
            CancelEdit();
            return;
        }

        targetUser.FirstName = editingUser.FirstName;
        targetUser.LastName = editingUser.LastName;
        targetUser.Email = editingUser.Email;
        targetUser.UserName = editingUser.Email;

        var updateResult = await UserManager.UpdateAsync(targetUser);
        if (!updateResult.Succeeded)
        {
            errorMessage = $"Update Failure: {string.Join(" ", updateResult.Errors.Select(e => e.Description))}";
            return;
        }

        var currentRoles = await UserManager.GetRolesAsync(targetUser);
        if (!currentRoles.Contains(editingUser.SelectedRole))
        {
            if (!await RoleManager.RoleExistsAsync(editingUser.SelectedRole))
            {
                await RoleManager.CreateAsync(new IdentityRole(editingUser.SelectedRole));
            }

            await UserManager.RemoveFromRolesAsync(targetUser, currentRoles);
            await UserManager.AddToRoleAsync(targetUser, editingUser.SelectedRole);
        }

        statusMessage = $"Successfully synchronized account details for profile: {editingUser.Email}";
        CancelEdit();
        await LoadUserRoster();
    }

    private void PromptDeleteUser(string userId)
    {
        userIdToConfirmDelete = userId;
        userIdToEdit = null;
        statusMessage = null;
        errorMessage = null;
    }

    private void CancelDelete()
    {
        userIdToConfirmDelete = null;
    }

    private async Task ConfirmDeleteUser(string userId)
    {
        userIdToConfirmDelete = null;
        var targetUser = await UserManager.FindByIdAsync(userId);
        if (targetUser == null || targetUser.TenantId != currentTenantId)
        {
            errorMessage = "Error: Could not locate the selected user record in the database.";
            return;
        }

        var result = await UserManager.DeleteAsync(targetUser);
        if (result.Succeeded)
        {
            statusMessage = $"Successfully removed account '{targetUser.Email}' from the system.";
            await LoadUserRoster();
        }
        else
        {
            errorMessage = $"Database Error: {string.Join(" ", result.Errors.Select(e => e.Description))}";
        }
    }
    private class UserDisplayModel
    {
        public string Id { get; set; } = string.Empty;
        public string FirstName { get; set; } = string.Empty;
        public string LastName { get; set; } = string.Empty;
        public string Email { get; set; } = string.Empty;
        public string SelectedRole { get; set; } = string.Empty;
    }
}
