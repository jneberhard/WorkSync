@page "/SuperAdmin/Tenants"

@using Microsoft.AspNetCore.Authorization
@using Microsoft.EntityFrameworkCore
@using WorkSync.Data

@attribute [Authorize(Roles = "SuperUser")]
@inject IDbContextFactory<ApplicationDbContext> DbFactory

<PageTitle>Tenant Management | WorkSync</PageTitle>

<div class="container mt-4">
    <h1>Tenant Management</h1>
    <p class="text-secondary">
        Approve company requests, archive unpaid workspaces without losing data, and restore access when needed.
    </p>

    @if (!string.IsNullOrWhiteSpace(Message))
    {
        <div class="alert @(Succeeded ? "alert-success" : "alert-danger")" role="status">@Message</div>
    }

    <h2 class="h4 mt-4">Pending tenant requests</h2>
    @if (requests.Count == 0)
    {
        <p>No tenant requests are waiting.</p>
    }
    else
    {
        <div class="table-responsive">
            <table class="table align-middle">
                <thead><tr><th>Company</th><th>Administrator</th><th>Requested</th><th>Status</th><th></th></tr></thead>
                <tbody>
                @foreach (var request in requests)
                {
                    <tr>
                        <td>@request.CompanyName</td>
                        <td>@request.AdminEmail</td>
                        <td>@request.RequestedAtUtc.ToString("yyyy-MM-dd")</td>
                        <td>
                            @(string.IsNullOrEmpty(request.AdminUserId)
                                ? "Needs administrator credentials"
                                : "Ready for approval")
                        </td>
                        <td class="text-end">
                            <form action="/SuperAdmin/ApproveTenant" method="post">
                                <AntiforgeryToken />
                                <input type="hidden" name="requestId" value="@request.Id" />
                                <button class="btn btn-primary btn-sm"
                                        type="submit"
                                        disabled="@string.IsNullOrEmpty(request.AdminUserId)">
                                    Approve tenant and admin
                                </button>
                            </form>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }

    <h2 class="h4 mt-5">Companies</h2>
    <div class="table-responsive">
        <table class="table align-middle">
            <thead><tr><th>Company</th><th>Tenant ID</th><th>Administrator</th><th>Status</th><th></th></tr></thead>
            <tbody>
            @foreach (var tenant in tenants)
            {
                <tr>
                    <td>@tenant.Name</td>
                    <td><strong>@tenant.Id</strong></td>
                    <td>@tenant.AdminEmail</td>
                    <td>
                        @if (tenant.IsActive)
                        {
                            <span class="badge text-bg-success">Active</span>
                        }
                        else
                        {
                            <span class="badge text-bg-secondary">Archived</span>
                            @if (tenant.ArchivedAtUtc is DateTime archivedAtUtc)
                            {
                                <div class="small text-secondary mt-1">
                                    @archivedAtUtc.ToString("yyyy-MM-dd")
                                </div>
                            }
                        }
                    </td>
                    <td class="text-end">
                        <form action="/SuperAdmin/SetTenantArchived" method="post"
                              class="d-inline-block mb-2">
                            <AntiforgeryToken />
                            <input type="hidden" name="tenantId" value="@tenant.Id" />
                            <input type="hidden" name="archive" value="@tenant.IsActive.ToString().ToLowerInvariant()" />
                            <button class="btn @(tenant.IsActive ? "btn-outline-warning" : "btn-outline-success") btn-sm"
                                    type="submit">
                                @(tenant.IsActive ? "Archive workspace" : "Restore workspace")
                            </button>
                        </form>

                        <details>
                            <summary class="small text-danger">Permanently remove tenant</summary>
                            <form action="/SuperAdmin/RemoveTenant" method="post"
                                  class="d-inline-flex align-items-center gap-2 mt-2">
                            <AntiforgeryToken />
                            <input type="hidden" name="tenantId" value="@tenant.Id" />
                            <label class="visually-hidden" for="confirm-tenant-@tenant.Id">
                                Confirm tenant ID
                            </label>
                            <input id="confirm-tenant-@tenant.Id"
                                   class="form-control form-control-sm"
                                   style="width: 8rem"
                                   type="text"
                                   inputmode="numeric"
                                   name="tenantIdConfirmation"
                                   placeholder="Type @tenant.Id"
                                   required />
                            <button class="btn btn-outline-danger btn-sm" type="submit">
                                Permanently remove
                            </button>
                            </form>
                        </details>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>

@code {
    private List<TenantRequest> requests = [];
    private List<Tenant> tenants = [];

    [SupplyParameterFromQuery(Name = "message")]
    private string? Message { get; set; }

    [SupplyParameterFromQuery(Name = "succeeded")]
    private bool Succeeded { get; set; }

    protected override async Task OnInitializedAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        requests = await db.TenantRequests.AsNoTracking()
            .Where(request => !request.IsApproved)
            .OrderBy(request => request.RequestedAtUtc)
            .ToListAsync();
        tenants = await db.Tenants.AsNoTracking().OrderBy(tenant => tenant.Name).ToListAsync();
    }
}
