@page "/reports"
@rendermode InteractiveServer
@inject WorkSyncService Service
@inject IJSRuntime JS
@attribute [Authorize(Roles = "Admin,Leader")]

<PageTitle>Reports</PageTitle>

<div class="report-header">
    <h1>Reports</h1>
    <p class="report-subtitle">
        Track workorders, assignments, and follow-up items across the company.
        Use the filters to narrow every section at once.
    </p>
</div>

<div class="report-filters">
    <div class="report-filters-grid">
        <div class="report-filter">
            <label class="form-label" for="department-filter">Department</label>
            <InputSelect id="department-filter" @bind-Value="departmentFilter">
                <option value="">All Departments</option>
                @foreach (var department in departments)
                {
                    <option value="@department">@department</option>
                }
            </InputSelect>
        </div>

        <div class="report-filter">
            <label class="form-label" for="owner-filter">Owner</label>
            <InputSelect id="owner-filter" @bind-Value="ownerFilter">
                <option value="">All Owners</option>
                @foreach (var owner in owners)
                {
                    <option value="@owner">@owner</option>
                }
            </InputSelect>
        </div>

        <div class="report-filter">
            <label class="form-label" for="status-filter">Status</label>
            <InputSelect id="status-filter" @bind-Value="statusFilter">
                <option value="">All Status</option>
                @foreach (var status in statuses)
                {
                    <option value="@status">@status</option>
                }
            </InputSelect>
        </div>

        <div class="report-filter">
            <label class="form-label" for="due-from-filter">Due From</label>
            <InputDate id="due-from-filter" @bind-Value="dueDateFrom" />
        </div>

        <div class="report-filter">
            <label class="form-label" for="due-to-filter">Due To</label>
            <InputDate id="due-to-filter" @bind-Value="dueDateTo" />
        </div>
    </div>

    <div class="report-filters-footer">
        <p class="report-filter-status">
            @(HasActiveFilters
                ? ActiveFilterCount == 1 ? "1 filter active" : $"{ActiveFilterCount} filters active"
                : "Showing all records")
        </p>

        <button type="button"
                class="btn-secondary"
                disabled="@(!HasActiveFilters)"
                @onclick="ClearFilters">
            Clear Filters
        </button>
    </div>
</div>

<section class="report-export" aria-labelledby="export-title">
    <div>
        <h2 id="export-title">Export Report</h2>
        <p>
            Download or copy a simple text summary using the current filters.
        </p>
        @if (!string.IsNullOrWhiteSpace(copyMessage))
        {
            <p class="report-export-status">@copyMessage</p>
        }
    </div>

    <div class="report-export-actions">
        <button type="button" class="btn-secondary" @onclick="DownloadReport">
            Download Report
        </button>
        <button type="button" class="btn-secondary" @onclick="CopyReport">
            Copy Report
        </button>
    </div>
</section>

@{
    // Snapshot computed properties once so each section uses the same filtered results
    // without re-evaluating the LINQ queries for every template reference below.
    var openWorkorders = OpenWorkorders;
    var workordersNeedingFollowUp = WorkordersNeedingFollowUp;
    var openAssignmentsByOwner = OpenAssignmentsByOwner;
    var overdueAssignments = OverdueAssignments;
    var completedAssignments = CompletedAssignments;
    var overdueFollowUps = OverdueFollowUps;
}

<nav class="report-nav" aria-label="Report sections">
    <a href="#open-workorders">Open Workorders <span class="report-nav-count">@openWorkorders.Count</span></a>
    <a href="#workorders-follow-up">Needing Follow-Up <span class="report-nav-count">@workordersNeedingFollowUp.Count</span></a>
    <a href="#assignments-by-owner">By Owner <span class="report-nav-count">@openAssignmentsByOwner.Sum(g => g.Value.Count)</span></a>
    <a href="#overdue-assignments">Overdue <span class="report-nav-count">@overdueAssignments.Count</span></a>
    <a href="#completed-assignments">Completed <span class="report-nav-count">@completedAssignments.Count</span></a>
    <a href="#overdue-follow-ups">Overdue Follow-Ups <span class="report-nav-count">@overdueFollowUps.Count</span></a>
</nav>

<section id="open-workorders" class="report-section">
    <div class="report-section-header">
        <h2>Open Workorders</h2>
        <span class="report-count">@openWorkorders.Count</span>
    </div>

    @if (openWorkorders.Count == 0)
    {
        <p class="report-empty">@EmptyMessage("open workorders")</p>
    }
    else
    {
        <div class="table-scroll">
            <table class="table">
                <thead>
                    <tr>
                        <th>Title</th>
                        <th>Department</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var workorder in openWorkorders)
                    {
                        <tr>
                            <td>@workorder.Title</td>
                            <td>@workorder.Department</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</section>

<section id="workorders-follow-up" class="report-section">
    <div class="report-section-header">
        <h2>Workorders Needing Follow-Up</h2>
        <span class="report-count">@workordersNeedingFollowUp.Count</span>
    </div>

    @if (workordersNeedingFollowUp.Count == 0)
    {
        <p class="report-empty">@EmptyMessage("workorders needing follow-up")</p>
    }
    else
    {
        <div class="table-scroll">
            <table class="table">
                <thead>
                    <tr>
                        <th>Title</th>
                        <th>Department</th>
                        <th>Assigned Employee</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var workorder in workordersNeedingFollowUp)
                    {
                        <tr>
                            <td>@workorder.Title</td>
                            <td>@workorder.Department</td>
                            <td>@workorder.AssignedEmployee</td>
                            <td><span class="@StatusBadgeClass(workorder.Status)">@workorder.Status</span></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</section>

<section id="assignments-by-owner" class="report-section">
    <div class="report-section-header">
        <h2>Assignments by Owner</h2>
        <span class="report-count">@openAssignmentsByOwner.Sum(g => g.Value.Count)</span>
    </div>

    @if (openAssignmentsByOwner.Count == 0)
    {
        <p class="report-empty">@EmptyMessage("open assignments")</p>
    }
    else
    {
        @foreach (var group in openAssignmentsByOwner)
        {
            <div class="report-owner-group">
                <h3>@group.Key <span class="report-count">@group.Value.Count</span></h3>
                <div class="table-scroll">
                    <table class="table">
                        <thead>
                            <tr>
                                <th>Title</th>
                                <th>Department</th>
                                <th>Due Date</th>
                                <th>Priority</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in group.Value)
                            {
                                <tr>
                                    <td>@item.Title</td>
                                    <td>@item.Department</td>
                                    <td class="@(item.DueDate < DateTime.Today ? "overdue-date" : null)">
                                        @item.DueDate.ToShortDateString()
                                    </td>
                                    <td><span class="@PriorityBadgeClass(item.Priority)">@item.Priority</span></td>
                                    <td><span class="@StatusBadgeClass(item.Status)">@item.Status</span></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    }
</section>

<section id="overdue-assignments" class="report-section">
    <div class="report-section-header">
        <h2>Overdue Assignments</h2>
        <span class="report-count">@overdueAssignments.Count</span>
    </div>

    @if (overdueAssignments.Count == 0)
    {
        <p class="report-empty">@EmptyMessage("overdue assignments")</p>
    }
    else
    {
        <div class="table-scroll">
            <table class="table">
                <thead>
                    <tr>
                        <th>Title</th>
                        <th>Owner</th>
                        <th>Department</th>
                        <th>Due Date</th>
                        <th>Priority</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in overdueAssignments)
                    {
                        <tr>
                            <td>@item.Title</td>
                            <td>@item.AssignedOwner</td>
                            <td>@item.Department</td>
                            <td class="overdue-date">@item.DueDate.ToShortDateString()</td>
                            <td><span class="@PriorityBadgeClass(item.Priority)">@item.Priority</span></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</section>

<section id="completed-assignments" class="report-section">
    <div class="report-section-header">
        <h2>Completed Assignments</h2>
        <span class="report-count">@completedAssignments.Count</span>
    </div>

    @if (completedAssignments.Count == 0)
    {
        <p class="report-empty">@EmptyMessage("completed assignments")</p>
    }
    else
    {
        <div class="table-scroll">
            <table class="table">
                <thead>
                    <tr>
                        <th>Title</th>
                        <th>Owner</th>
                        <th>Department</th>
                        <th>Completion Date</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in completedAssignments)
                    {
                        <tr>
                            <td>@item.Title</td>
                            <td>@item.AssignedOwner</td>
                            <td>@item.Department</td>
                            <td>@(item.CompletionDate.HasValue ? item.CompletionDate.Value.ToShortDateString() : "—")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</section>

<section id="overdue-follow-ups" class="report-section">
    <div class="report-section-header">
        <h2>Overdue Follow-Up Items</h2>
        <span class="report-count">@overdueFollowUps.Count</span>
    </div>

    @if (overdueFollowUps.Count == 0)
    {
        <p class="report-empty">@EmptyMessage("overdue follow-up items")</p>
    }
    else
    {
        <div class="table-scroll">
            <table class="table">
                <thead>
                    <tr>
                        <th>Title</th>
                        <th>Owner</th>
                        <th>Related Project</th>
                        <th>Due Date</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in overdueFollowUps)
                    {
                        <tr>
                            <td>@item.FollowUpItemTitle</td>
                            <td>@item.AssignedOwner</td>
                            @* Hide the project name when the follow-up is marked confidential. *@
                            <td>@(item.IsConfidential ? "— Confidential —" : item.RelatedProject)</td>
                            <td class="overdue-date">@item.DueDate.ToShortDateString()</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</section>

@code {
    private List<Workorder> workorders = new();
    private List<AssignmentItem> assignments = new();
    private List<FollowUpItem> followUps = new();

    private List<string> departments = new();
    private List<string> owners = new();
    private List<string> statuses = new();

    private string departmentFilter = string.Empty;
    private string ownerFilter = string.Empty;
    private string statusFilter = string.Empty;
    private DateTime? dueDateFrom;
    private DateTime? dueDateTo;
    private string copyMessage = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        workorders = await Service.GetWorkordersAsync();
        assignments = await Service.GetAssignmentsAsync();
        followUps = await Service.GetFollowUpsAsync();

        // Build filter dropdown options by merging distinct values from all data types.
        // Departments come from both workorders and assignments; owners from assignments and follow-ups.
        departments = workorders.Select(c => c.Department)
            .Concat(assignments.Select(a => a.Department))
            .Where(o => !string.IsNullOrWhiteSpace(o))
            .Distinct()
            .OrderBy(o => o)
            .ToList();

        owners = assignments.Select(a => a.AssignedOwner)
            .Concat(followUps.Select(f => f.AssignedOwner))
            .Where(l => !string.IsNullOrWhiteSpace(l))
            .Distinct()
            .OrderBy(l => l)
            .ToList();

        statuses = workorders.Select(c => c.Status)
            .Concat(assignments.Select(a => a.Status))
            .Concat(followUps.Select(f => f.Status))
            .Where(s => !string.IsNullOrWhiteSpace(s))
            .Distinct()
            .OrderBy(s => s)
            .ToList();
    }

    private bool HasActiveFilters =>
        !string.IsNullOrEmpty(departmentFilter) ||
        !string.IsNullOrEmpty(ownerFilter) ||
        !string.IsNullOrEmpty(statusFilter) ||
        dueDateFrom.HasValue ||
        dueDateTo.HasValue;

    private int ActiveFilterCount =>
        (string.IsNullOrEmpty(departmentFilter) ? 0 : 1) +
        (string.IsNullOrEmpty(ownerFilter) ? 0 : 1) +
        (string.IsNullOrEmpty(statusFilter) ? 0 : 1) +
        (dueDateFrom.HasValue ? 1 : 0) +
        (dueDateTo.HasValue ? 1 : 0);

    private void ClearFilters()
    {
        departmentFilter = string.Empty;
        ownerFilter = string.Empty;
        statusFilter = string.Empty;
        dueDateFrom = null;
        dueDateTo = null;
        copyMessage = string.Empty;
    }

    private string EmptyMessage(string what) =>
        HasActiveFilters ? $"No {what} match the current filters." : $"No {what}.";

    private static string StatusBadgeClass(string status) =>
        "ws-badge badge-" + status.ToLowerInvariant().Replace(" ", "-");

    private static string PriorityBadgeClass(string priority) =>
        "ws-badge badge-priority-" + priority.ToLowerInvariant();

    // Workorders have no owner or due date, so only the department and status filters apply.
    private IEnumerable<Workorder> FilteredWorkorders =>
        workorders.Where(c =>
            (string.IsNullOrEmpty(departmentFilter) || c.Department == departmentFilter) &&
            (string.IsNullOrEmpty(statusFilter) || c.Status == statusFilter));

    private IEnumerable<AssignmentItem> FilteredAssignments =>
        assignments.Where(a =>
            (string.IsNullOrEmpty(departmentFilter) || a.Department == departmentFilter) &&
            (string.IsNullOrEmpty(ownerFilter) || a.AssignedOwner == ownerFilter) &&
            (string.IsNullOrEmpty(statusFilter) || a.Status == statusFilter) &&
            (!dueDateFrom.HasValue || a.DueDate.Date >= dueDateFrom.Value.Date) &&
            (!dueDateTo.HasValue || a.DueDate.Date <= dueDateTo.Value.Date));

    // Follow-ups have no department, so only the owner, status, and due date filters apply.
    private IEnumerable<FollowUpItem> FilteredFollowUps =>
        followUps.Where(f =>
            (string.IsNullOrEmpty(ownerFilter) || f.AssignedOwner == ownerFilter) &&
            (string.IsNullOrEmpty(statusFilter) || f.Status == statusFilter) &&
            (!dueDateFrom.HasValue || f.DueDate.Date >= dueDateFrom.Value.Date) &&
            (!dueDateTo.HasValue || f.DueDate.Date <= dueDateTo.Value.Date));

    private List<Workorder> OpenWorkorders =>
        FilteredWorkorders.Where(c => c.Status == "Open").ToList();

    private List<Workorder> WorkordersNeedingFollowUp =>
        FilteredWorkorders.Where(c => c.NeedsFollowUp).ToList();

    // Groups non-completed assignments by owner name, sorted alphabetically by owner
    // and then by due date within each group so the most urgent items appear first.
    private Dictionary<string, List<AssignmentItem>> OpenAssignmentsByOwner =>
        FilteredAssignments
            .Where(a => a.Status != "Completed")
            .GroupBy(a => a.AssignedOwner)
            .OrderBy(g => g.Key)
            .ToDictionary(g => g.Key, g => g.OrderBy(a => a.DueDate).ToList());

    private List<AssignmentItem> OverdueAssignments =>
        FilteredAssignments
            .Where(a => a.DueDate < DateTime.Today && a.Status != "Completed")
            .OrderBy(a => a.DueDate)
            .ToList();

    private List<AssignmentItem> CompletedAssignments =>
        FilteredAssignments
            .Where(a => a.Status == "Completed")
            .OrderByDescending(a => a.CompletionDate)
            .ToList();

    private List<FollowUpItem> OverdueFollowUps =>
        FilteredFollowUps
            .Where(f => f.DueDate < DateTime.Today && f.Status != "Completed")
            .OrderBy(f => f.DueDate)
            .ToList();

    private async Task DownloadReport()
    {
        var reportText = BuildReportText();
        var fileName = $"WorkSync-Report-{DateTime.Today:yyyy-MM-dd}.txt";

        await JS.InvokeVoidAsync("workSyncReports.downloadTextFile", fileName, reportText);
        copyMessage = "Report downloaded.";
    }

    private async Task CopyReport()
    {
        await JS.InvokeVoidAsync("workSyncReports.copyText", BuildReportText());
        copyMessage = "Report copied.";
    }

    private string BuildReportText()
    {
        var openWorkorders = OpenWorkorders;
        var workordersNeedingFollowUp = WorkordersNeedingFollowUp;
        var openAssignmentsByOwner = OpenAssignmentsByOwner;
        var overdueAssignments = OverdueAssignments;
        var completedAssignments = CompletedAssignments;
        var overdueFollowUps = OverdueFollowUps;

        var report = new System.Text.StringBuilder();

        report.AppendLine("WorkSync Report");
        report.AppendLine($"Created: {DateTime.Now:g}");
        report.AppendLine($"Filters: {FilterSummary}");
        report.AppendLine();

        report.AppendLine("Summary");
        report.AppendLine($"- Open workorders: {openWorkorders.Count}");
        report.AppendLine($"- Workorders needing follow-up: {workordersNeedingFollowUp.Count}");
        report.AppendLine($"- Open assignments: {openAssignmentsByOwner.Sum(g => g.Value.Count)}");
        report.AppendLine($"- Overdue assignments: {overdueAssignments.Count}");
        report.AppendLine($"- Completed assignments: {completedAssignments.Count}");
        report.AppendLine($"- Overdue follow-up items: {overdueFollowUps.Count}");
        report.AppendLine();

        AppendWorkorderSection(report, "Open Workorders", openWorkorders);
        AppendWorkorderSection(report, "Workorders Needing Follow-Up", workordersNeedingFollowUp);

        report.AppendLine("Assignments by Owner");
        if (openAssignmentsByOwner.Count == 0)
        {
            report.AppendLine("- None");
        }
        else
        {
            foreach (var group in openAssignmentsByOwner)
            {
                report.AppendLine($"- {group.Key}: {group.Value.Count}");
                foreach (var item in group.Value)
                {
                    report.AppendLine($"  - {item.Title} | {item.Department} | Due {item.DueDate:d} | {item.Priority} | {item.Status}");
                }
            }
        }
        report.AppendLine();

        AppendAssignmentSection(report, "Overdue Assignments", overdueAssignments);
        AppendAssignmentSection(report, "Completed Assignments", completedAssignments);

        report.AppendLine("Overdue Follow-Up Items");
        if (overdueFollowUps.Count == 0)
        {
            report.AppendLine("- None");
        }
        else
        {
            foreach (var item in overdueFollowUps)
            {
                // Keep private project names out of exported reports too.
                var project = item.IsConfidential ? "Confidential" : item.RelatedProject;
                report.AppendLine($"- {item.FollowUpItemTitle} | {item.AssignedOwner} | {project} | Due {item.DueDate:d}");
            }
        }

        return report.ToString();
    }

    private string FilterSummary
    {
        get
        {
            if (!HasActiveFilters)
            {
                return "None";
            }

            var filters = new List<string>();

            if (!string.IsNullOrEmpty(departmentFilter))
            {
                filters.Add($"Department: {departmentFilter}");
            }

            if (!string.IsNullOrEmpty(ownerFilter))
            {
                filters.Add($"Owner: {ownerFilter}");
            }

            if (!string.IsNullOrEmpty(statusFilter))
            {
                filters.Add($"Status: {statusFilter}");
            }

            if (dueDateFrom.HasValue)
            {
                filters.Add($"Due from: {dueDateFrom.Value:d}");
            }

            if (dueDateTo.HasValue)
            {
                filters.Add($"Due to: {dueDateTo.Value:d}");
            }

            return string.Join("; ", filters);
        }
    }

    private static void AppendWorkorderSection(System.Text.StringBuilder report, string title, List<Workorder> items)
    {
        report.AppendLine(title);

        if (items.Count == 0)
        {
            report.AppendLine("- None");
        }
        else
        {
            foreach (var item in items)
            {
                report.AppendLine($"- {item.Title} | {item.Department} | {item.Status}");
            }
        }

        report.AppendLine();
    }

    private static void AppendAssignmentSection(System.Text.StringBuilder report, string title, List<AssignmentItem> items)
    {
        report.AppendLine(title);

        if (items.Count == 0)
        {
            report.AppendLine("- None");
        }
        else
        {
            foreach (var item in items)
            {
                report.AppendLine($"- {item.Title} | {item.AssignedOwner} | {item.Department} | Due {item.DueDate:d} | {item.Status}");
            }
        }

        report.AppendLine();
    }
}
