@page "/workorders"
@rendermode InteractiveServer
@inject WorkSyncService Service
@inject NavigationManager Navigation

@attribute [Authorize(Roles = "Admin,Leader")]

<PageTitle>Workorders | WorkSync</PageTitle>

<h1>Workorder Tracker</h1>

@if (showForm)
{
    <div class="card" style="margin-bottom: 2rem;">
        <h3>@(isEditing ? "Edit Workorder" : "Create New Workorder")</h3>
        
        <!-- EditForm with validation - OnValidSubmit only fires when all validation passes -->
        <EditForm EditContext="editContext" OnValidSubmit="SaveWorkorder" OnInvalidSubmit="HandleInvalidSubmit">
            <DataAnnotationsValidator />
            
            <!-- Validation summary - displays all validation errors at the top -->
            <div class="validation-summary-errors" role="alert" style="display: @(formError ? "block" : "none")">
                <ul>
                    @if (formError)
                    {
                        @foreach (var error in validationErrors)
                        {
                            <li>@error</li>
                        }
                    }
                </ul>
            </div>
            
            <div class="form-grid">
                <!-- Each form field shows individual validation message below it -->
                <div class="form-field">
                    <label>Workorder Title</label>
                    <InputText @bind-Value="currentWorkorder.Title" />
                    <ValidationMessage For="@(() => currentWorkorder.Title)" />
                </div>

                <div class="form-field">
                    <label>Department</label>
                    <InputText @bind-Value="currentWorkorder.Department" />
                    <ValidationMessage For="@(() => currentWorkorder.Department)" />
                </div>

                <div class="form-field">
                    <label>Assigned Employee</label>
                    <InputText @bind-Value="currentWorkorder.AssignedEmployee" />
                    <ValidationMessage For="@(() => currentWorkorder.AssignedEmployee)" />
                </div>

                <div class="form-field">
                    <label>Status</label>
                    <InputSelect @bind-Value="currentWorkorder.Status">
                        <option value="Open">Open</option>
                        <option value="In Progress">In Progress</option>
                        <option value="Completed">Completed</option>
                    </InputSelect>
                    <ValidationMessage For="@(() => currentWorkorder.Status)" />
                </div>

                <div class="form-field">
                    <label>
                        <InputCheckbox @bind-Value="currentWorkorder.NeedsFollowUp" />
                        Needs Follow-Up
                    </label>
                </div>

                <div class="form-field">
                    <label>Created Date</label>
                    <InputDate @bind-Value="currentWorkorder.CreatedDate" />
                    <ValidationMessage For="@(() => currentWorkorder.CreatedDate)" />
                </div>

                <div class="form-field">
                    <label>Due Date</label>
                    <InputDate @bind-Value="currentWorkorder.DueDate" />
                    <ValidationMessage For="@(() => currentWorkorder.DueDate)" />
                </div>

                <div class="form-field">
                    <label>Completed Date</label>
                    <InputDate @bind-Value="currentWorkorder.CompletedDate" />
                    <ValidationMessage For="@(() => currentWorkorder.CompletedDate)" />
                </div>

                <div class="form-field">
                    <label>Notes</label>
                    <InputTextArea @bind-Value="currentWorkorder.Notes" rows="3" />
                    <ValidationMessage For="@(() => currentWorkorder.Notes)" />
                </div>
            </div>

            <div class="button-group">
                <button type="submit" class="btn-primary">@(isEditing ? "Update Workorder" : "+ Add Workorder")</button>
                <button type="button" class="btn-secondary" @onclick="CancelForm">Cancel</button>
            </div>
        </EditForm>
    </div>
}

<div style="margin-bottom: 1rem;">
    <button class="btn-primary" @onclick="ShowCreateForm">+ Add New Workorder</button>
    <button class="btn-secondary" @onclick="RefreshData" style="margin-left: 0.5rem;">Refresh</button>
</div>

<!-- Filter row for searching and filtering workorders -->
<div class="filter-row">
    <div class="search-box">
        <label class="visually-hidden" for="workorder-search">Search workorders</label>
        <span class="search-icon">🔍</span>
        <InputText id="workorder-search"
                   @bind-Value="searchText"
                   placeholder="Search workorders..." />
    </div>

    <label class="visually-hidden" for="workorder-status-filter">Filter workorders by status</label>
    <InputSelect id="workorder-status-filter" @bind-Value="statusFilter">
        <option value="">All Status</option>
        <option value="Open">Open</option>
        <option value="In Progress">In Progress</option>
        <option value="Completed">Completed</option>
    </InputSelect>
</div>

@if (isLoading)
{
    <div class="loading">
        <p>Loading workorders...</p>
    </div>
}
else if (errorMessage != null)
{
    <div class="alert alert-danger">
        <p><strong>Error:</strong> @errorMessage</p>
    </div>
}
else if (FilteredWorkorders.Any())
{
    <div class="table-responsive">
        <table class="table">
            <thead>
                <tr>
                    <th>Title</th>
                    <th>Department</th>
                    <th>Assigned Employee</th>
                    <th>Status</th>
                    <th>Follow-Up</th>
                    <th>Created Date</th>
                    <th>Due Date</th>
                    <th>Completed Date</th>
                    <th>Notes</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                <!-- Display filtered workorders with edit and delete buttons -->
                @foreach (var workorder in FilteredWorkorders)
                {
                    <tr>
                        <td>@workorder.Title</td>
                        <td>@workorder.Department</td>
                        <td>@workorder.AssignedEmployee</td>
                        <td>@workorder.Status</td>
                        <td>@(workorder.NeedsFollowUp ? "Yes" : "No")</td>
                        <td>@(workorder.CreatedDate?.ToString("yyyy-MM-dd") ?? "-")</td>
                        <td>@(workorder.DueDate?.ToString("yyyy-MM-dd") ?? "-")</td>
                        <td>@(workorder.CompletedDate?.ToString("yyyy-MM-dd") ?? "-")</td>
                        <td>@workorder.Notes</td>
                        <td>
                            <button class="btn-edit" @onclick="() => EditWorkorder(workorder)">Edit</button>
                            <button class="btn-delete" @onclick="() => DeleteWorkorder(workorder.Id)">Delete</button>
                         </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    <div class="alert alert-info">
        <small>Total workorders: @FilteredWorkorders.Count() (filtered from @workorders.Count total)</small>
    </div>
}
else
{
    <div class="empty-state">
        <p>No workorders found. Click "Add New Workorder" to get started!</p>
    </div>
}

<!-- Delete confirmation modal -->
@if (showDeleteConfirmation)
{
    <div class="modal-overlay">
        <div class="modal-content">
            <h3>Confirm Delete</h3>
            <p>Are you sure you want to delete this workorder?</p>
            <p><strong>@workorderToDelete?.Title</strong> - @workorderToDelete?.Department</p>
            <div class="button-group">
                <button class="btn-delete" @onclick="ConfirmDelete">Yes, Delete</button>
                <button class="btn-secondary" @onclick="CancelDelete">Cancel</button>
            </div>
        </div>
    </div>
}

@code {
    // Data and state properties
    private List<Workorder> workorders = new();
    private Workorder currentWorkorder = new();
    private Workorder? workorderToDelete = null;
    private EditContext? editContext;
    private bool showForm = false;
    private bool isEditing = false;
    private bool showDeleteConfirmation = false;
    private bool isLoading = true;
    private bool formError = false;
    private List<string> validationErrors = new();
    private string? errorMessage = null;
    
    // Filter properties
    private string searchText = string.Empty;
    private string statusFilter = string.Empty;

    // Load data when page first renders
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await LoadData();
        }
    }

    private async Task RefreshData()
    {
        await LoadData();
    }

    // Fetch all workorders from the database
    private async Task LoadData()
    {
        try
        {
            isLoading = true;
            errorMessage = null;
            StateHasChanged();
            
            workorders = await Service.GetWorkordersAsync();
            
            isLoading = false;
            StateHasChanged();
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
            isLoading = false;
            StateHasChanged();
        }
    }

    // Filter workorders based on search text and status filter
    private IEnumerable<Workorder> FilteredWorkorders
    {
        get
        {
            var query = workorders.AsEnumerable();

            if (!string.IsNullOrWhiteSpace(searchText))
            {
                query = query.Where(c =>
                    c.Title.Contains(searchText, StringComparison.OrdinalIgnoreCase) ||
                    c.Department.Contains(searchText, StringComparison.OrdinalIgnoreCase) ||
                    c.AssignedEmployee.Contains(searchText, StringComparison.OrdinalIgnoreCase) ||
                    c.Status.Contains(searchText, StringComparison.OrdinalIgnoreCase) ||
                    c.Notes.Contains(searchText, StringComparison.OrdinalIgnoreCase));
            }

            if (!string.IsNullOrWhiteSpace(statusFilter))
            {
                query = query.Where(c => c.Status == statusFilter);
            }

            return query.OrderBy(c => c.Title);
        }
    }

    // Initialize form for creating a new workorder
    private void ShowCreateForm()
    {
        currentWorkorder = new Workorder();
        isEditing = false;
        showForm = true;
        formError = false;
        validationErrors.Clear();
        editContext = new EditContext(currentWorkorder);
        
        // Real-time validation as user types
        editContext.OnFieldChanged += (sender, e) =>
        {
            formError = !editContext.Validate();
            StateHasChanged();
        };
        
        StateHasChanged();
    }

    // Populate form with existing workorder data for editing
    private void EditWorkorder(Workorder workorder)
    {
        currentWorkorder = new Workorder
        {
            Id = workorder.Id,
            Title = workorder.Title,
            Department = workorder.Department,
            AssignedEmployee = workorder.AssignedEmployee,
            Status = workorder.Status,
            NeedsFollowUp = workorder.NeedsFollowUp,
            CreatedDate = workorder.CreatedDate,
            DueDate = workorder.DueDate,
            CompletedDate = workorder.CompletedDate,
            Notes = workorder.Notes
        };
        isEditing = true;
        showForm = true;
        formError = false;
        validationErrors.Clear();
        editContext = new EditContext(currentWorkorder);
        
        editContext.OnFieldChanged += (sender, e) =>
        {
            formError = !editContext.Validate();
            StateHasChanged();
        };
        
        StateHasChanged();
    }

    // Collect all validation errors when form submission fails
    private void HandleInvalidSubmit()
    {
        formError = true;
        validationErrors.Clear();
        
        var validationMessages = editContext?.GetValidationMessages();
        if (validationMessages != null)
        {
            validationErrors.AddRange(validationMessages);
        }
        
        StateHasChanged();
    }

    // Save or update workorder based on isEditing flag
    private async Task SaveWorkorder()
    {
        formError = false;
        validationErrors.Clear();
        
        if (isEditing)
        {
            await Service.UpdateWorkorderAsync(currentWorkorder);
        }
        else
        {
            await Service.AddWorkorderAsync(currentWorkorder);
        }

        showForm = false;
        currentWorkorder = new Workorder();
        await LoadData();
    }

    private void CancelForm()
    {
        showForm = false;
        currentWorkorder = new Workorder();
        isEditing = false;
        formError = false;
        validationErrors.Clear();
        StateHasChanged();
    }

    // Show delete confirmation modal
    private void DeleteWorkorder(int id)
    {
        workorderToDelete = workorders.FirstOrDefault(c => c.Id == id);
        showDeleteConfirmation = true;
        StateHasChanged();
    }

    // Perform actual deletion after confirmation
    private async Task ConfirmDelete()
    {
        if (workorderToDelete != null)
        {
            await Service.DeleteWorkorderAsync(workorderToDelete.Id);
            showDeleteConfirmation = false;
            workorderToDelete = null;
            await LoadData();
        }
    }

    private void CancelDelete()
    {
        showDeleteConfirmation = false;
        workorderToDelete = null;
        StateHasChanged();
    }
}
