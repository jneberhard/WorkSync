FROM mcr.microsoft.com/dotnet/sdk:10.0 AS build
WORKDIR /src

COPY WorkSync.csproj ./
RUN dotnet restore WorkSync.csproj

COPY . ./
RUN dotnet publish WorkSync.csproj -c Release -o /app/publish --no-restore

FROM mcr.microsoft.com/dotnet/aspnet:10.0 AS runtime
WORKDIR /app
COPY --from=build /app/publish ./

ENV ASPNETCORE_ENVIRONMENT=Production
CMD ["dotnet", "WorkSync.dll"]
